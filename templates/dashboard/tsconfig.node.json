{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": true,
    "noEmit": true,
    "composite": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "src/plugin/cuadrillaWatcher.ts",
    "src/server/metricsApiHandler.ts",
    "src/types/state.ts",
    "src/vite-env.d.ts",
    "../../src/runs.js",
    "../../src/dashboardLimits.js",
    "../../src/runs.d.ts",
    "../../src/dashboardLimits.d.ts"
  ]
}
