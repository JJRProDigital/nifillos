{
  "name": "nifillos",
  "version": "0.1.11",
  "description": "Multi-agent orchestration CLI for IDE-based AI cuadrillas",
  "type": "module",
  "bin": {
    "nifillos": "bin/nifillos.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/ bin/ tests/",
    "version": "node -e \"require('fs').writeFileSync('templates/_nifillos/.nifillos-version', require('./package.json').version + '\\n')\" && git add templates/_nifillos/.nifillos-version"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "cuadrillas"
  ],
  "author": "Obsessive Solutions",
  "homepage": "https://github.com/JJRProDigital/nifillos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JJRProDigital/nifillos.git"
  },
  "bugs": {
    "url": "https://github.com/JJRProDigital/nifillos/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "skills/",
    "templates/"
  ],
  "dependencies": {
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/input": "^5.0.0",
    "@inquirer/select": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0"
  }
}
